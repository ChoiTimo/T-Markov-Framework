# === SmartWAN Platform Environment Variables ===
# Copy this file to backend/.env and fill in values

# App
DEBUG=true
CORS_ORIGINS=http://localhost:5173,https://smartwan-platform.vercel.app

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Notion (Module catalog sync)
NOTION_API_KEY=secret_xxx
NOTION_MODULE_DB_ID=your-module-database-id
